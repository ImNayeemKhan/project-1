# ===== Core =====
NODE_ENV=production
PORT=4000
APP_NAME=Desh Communications
CORS_ORIGIN=http://localhost:3000

# ===== Database (MongoDB Atlas) =====
# Create a free cluster at https://cloud.mongodb.com, whitelist your VPS IP,
# then paste the SRV connection string here.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/isp?retryWrites=true&w=majority

# ===== Auth =====
# openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# ===== Redis (rate limiting, job locks) =====
REDIS_URL=redis://redis:6379

# ===== Logging =====
LOG_LEVEL=info

# ===== Seeding (initial admin) =====
SEED_ADMIN_EMAIL=admin@deshcommunications.net
SEED_ADMIN_PASSWORD=ChangeMe123!

# ===== MikroTik (placeholder) =====
# Populate when you connect a real router. Until then the adapter runs in dry-run mode.
MIKROTIK_ENABLED=false
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=api
MIKROTIK_PASSWORD=
MIKROTIK_TLS=false

# ===== RADIUS (placeholder) =====
RADIUS_ENABLED=false
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=testing123

# ===== Payment (mock bKash) =====
# Structured like real bKash Tokenized Checkout. Swap to live creds when ready.
BKASH_MODE=mock
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_CALLBACK_URL=http://localhost:4000/api/payments/bkash/callback

# ===== Billing =====
# Cron: 2am daily. Each day we (a) generate invoices for subscriptions whose
# nextBillingDate is today, (b) suspend subscriptions past the grace period.
BILLING_CRON=0 2 * * *
BILLING_GRACE_DAYS=3
